# ── Gemini API ──
GEMINI_API_KEY=AIzaSyDs5Tslf13jimFReip9nD7SfpKHEHF7qQU
GEMINI_MODEL=gemini-2.5-flash

# ── Authentication ──
# Leave empty to disable auth (development mode)
# Set a token to require X-API-Key header on all endpoints
API_AUTH_TOKEN=

# ── Database ──
# SQLite (default, good for local dev)
PB_DATABASE_URL=sqlite+aiosqlite:///./project_builder.db

# PostgreSQL (for production)
# PB_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/project_builder

# ── CORS ──
# JSON array of allowed origins, or ["*"] for all
CORS_ORIGINS=["*"]

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=10

# ── Cache ──
# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600
